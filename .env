# =========================================================
# APPLICATION
# =========================================================
APP_NAME=Malaria-Nutrition Predictor
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-this-secret-key
API_VERSION=v1

# =========================================================
# SERVER
# =========================================================
HOST=0.0.0.0
PORT=8000
WORKERS=4

# =========================================================
# DATABASE
# =========================================================
DATABASE_URL=postgresql+asyncpg://unicef_user:natacha@localhost:5432/malaria_db
DATABASE_SYNC_URL=postgresql://unicef_user:natacha@localhost:5432/malaria_db

DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

# =========================================================
# REDIS
# =========================================================
REDIS_URL=redis://localhost:6379/0

REDIS_CACHE_DB=1
REDIS_CELERY_DB=2

CACHE_TTL_PREDICTIONS=86400
CACHE_TTL_WEATHER=3600

# =========================================================
# CELERY
# =========================================================
CELERY_BROKER_URL=redis://localhost:6379/2
CELERY_RESULT_BACKEND=redis://localhost:6379/3
CELERY_TIMEZONE=Indian/Antananarivo

# =========================================================
# WEATHER APIs
# =========================================================
OPENWEATHER_API_KEY=e9c93d242ee527a613c489fbddfe2125
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5

COPERNICUS_USERNAME=tolojanaharynatachanoeline@gmail.com
COPERNICUS_PASSWORD=Natacha003.natacha

NASA_POWER_BASE_URL=https://power.larc.nasa.gov/api/temporal/daily/point

SENTINEL_HUB_CLIENT_ID=a944690d-d598-4f34-8e8b-1a3fc198ba1c
SENTINEL_HUB_CLIENT_SECRET=p3jzpUKH4ClOWfq0gCsPeGrBrdIR3RMS

# =========================================================
# HEALTH APIs
# =========================================================
DHIS2_BASE_URL=https://dhis.moh.gov.mg/api
