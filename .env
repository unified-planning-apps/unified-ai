# =========================================================
# NUTRITION APIs
# =========================================================
FAO_API_BASE_URL=https://openknowledge.fao.org/server

WFP_API_BASE_URL=https://api.efs.wfp.org/gefs


# =========================================================
# MACHINE LEARNING
# =========================================================
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=malaria-nutrition-madagascar

# =========================================================
# MINIO
# =========================================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

MINIO_BUCKET_REPORTS=unicef-reports
MINIO_BUCKET_MODELS=ml-models

MINIO_SECURE=false

# =========================================================
# JWT AUTH
# =========================================================
JWT_SECRET_KEY=super-secret-key
JWT_ALGORITHM=HS256

JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# =========================================================
# REPORTS
# =========================================================
REPORT_OUTPUT_DIR=/tmp/reports
REPORT_LANGUAGE=fr
WEEKLY_REPORT_DAY=0

# =========================================================
# LOGGING
# =========================================================
LOG_LEVEL=INFO
LOG_FILE=/tmp/malaria-predictor.log

# =========================================================
# MADAGASCAR REGIONS
# =========================================================
MADAGASCAR_REGIONS_COUNT=22
DEFAULT_REGION=Analamanga